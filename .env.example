# ══════════════════════════════════════════════════════════════
# EasyAlert Agent - Environment Configuration
# ══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in the required values.
#   cp .env.example .env
# ══════════════════════════════════════════════════════════════

# ── Required ─────────────────────────────────────────────────

# Central API URL (ec-im-api)
AGENT_API_URL=http://localhost:8080

# Agent API key (create from UI: Automation → Agents → Create Agent)
AGENT_API_KEY=ea_agent_xxxxx

# ── Optional ─────────────────────────────────────────────────

# Display name (default: hostname)
AGENT_NAME=dev-agent

# Job polling interval in seconds
POLL_INTERVAL=5

# Heartbeat interval in seconds
HEARTBEAT_INTERVAL=30

# Max parallel job executions (1-50)
MAX_CONCURRENT_JOBS=5

# Local admin API port
ADMIN_PORT=9191

# Bearer token for local admin API (auto-generated if empty)
ADMIN_TOKEN=

# Path to encrypted credential vault
VAULT_PATH=~/.easyalert/vault.json

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=DEBUG

# ── Security (dev only) ─────────────────────────────────────

# Allow HTTP executor to access private/internal IPs
ALLOW_PRIVATE_NETWORK=false

# Allow OS service executor to restart services
ALLOW_OS_RESTART=false
